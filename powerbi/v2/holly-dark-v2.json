        "valueAxis": [
          {
            "labelColor": { "solid": { "color": "#8892A0" } },
            "fontSize": 9,
            "gridlineColor": { "solid": { "color": "#2D2D5E" } }
          }
        ],
        "labels": [
          {
            "color": { "solid": { "color": "#FAFAFA" } },
            "fontSize": 9
          }
        ]
      }
    },
    "columnChart": {
      "*": {
        "categoryAxis": [
          {
            "labelColor": { "solid": { "color": "#8892A0" } },
            "fontSize": 9
          }
        ],
        "valueAxis": [
          {
            "labelColor": { "solid": { "color": "#8892A0" } },
            "fontSize": 9,
            "gridlineColor": { "solid": { "color": "#2D2D5E" } }
          }
        ],
        "labels": [
          {
            "color": { "solid": { "color": "#FAFAFA" } },
            "fontSize": 9
          }
        ]
      }
    },
    "clusteredColumnChart": {
      "*": {
        "categoryAxis": [
          {
            "labelColor": { "solid": { "color": "#8892A0" } },
            "fontSize": 9
