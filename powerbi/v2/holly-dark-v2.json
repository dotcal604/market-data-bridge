        ]
      }
    },
    "treemap": {
      "*": {
        "labels": [
          {
            "show": true,
            "color": { "solid": { "color": "#FAFAFA" } },
            "fontSize": 10
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": { "solid": { "color": "#FAFAFA" } },
            "fontSize": 10
          }
        ]
      }
    },
    "shape": {
      "*": {
        "fill": [
          {
            "fillColor": { "solid": { "color": "#1A1F2E" } },
            "transparency": 20
          }
        ],
        "line": [
          {
            "lineColor": { "solid": { "color": "#2D2D5E" } }
          }
        ]
      }
    },
    "textbox": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#0E111700" } },
            "transparency": 100
          }
        ]
      }
    },
    "actionButton": {
      "*": {
        "fill": [
          {
            "fillColor": { "solid": { "color": "#1A1F2E" } }
          }
        ],
        "outline": [
          {
            "outlineColor": { "solid": { "color": "#00D4AA" } },
            "weight": 1
          }
        ],
        "text": [
          {
            "fontColor": { "solid": { "color": "#00D4AA" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI Semibold"
          }
