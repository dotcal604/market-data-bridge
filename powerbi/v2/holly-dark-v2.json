        "values": [
          {
            "fontColorPrimary": { "solid": { "color": "#FAFAFA" } },
            "backColorPrimary": { "solid": { "color": "#1A1F2E" } },
            "fontColorSecondary": { "solid": { "color": "#FAFAFA" } },
            "backColorSecondary": { "solid": { "color": "#141824" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ],
        "total": [
          {
            "fontColor": { "solid": { "color": "#00D4FF" } },
