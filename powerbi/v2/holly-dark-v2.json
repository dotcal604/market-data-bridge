        "valueAxis": [
          {
            "labelColor": { "solid": { "color": "#8892A0" } },
            "fontSize": 9,
            "gridlineColor": { "solid": { "color": "#2D2D5E" } },
            "gridlineShow": true,
            "gridlineStyle": "solid"
          }
        ],
        "lineStyles": [
          {
            "strokeWidth": 2
