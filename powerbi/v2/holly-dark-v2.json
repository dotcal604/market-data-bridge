          }
        ],
        "categoryAxis": [
          {
            "labelColor": { "solid": { "color": "#8892A0" } },
            "fontSize": 9
          }
        ],
        "valueAxis": [
          {
            "labelColor": { "solid": { "color": "#8892A0" } },
