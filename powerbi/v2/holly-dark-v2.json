{
  "name": "Holly Dark v2",
  "dataColors": [
    "#00D4AA",
    "#FF4444",
    "#FFD700",
    "#00D4FF",
    "#7C4DFF",
    "#FF6E40",
    "#69F0AE",
    "#448AFF",
    "#EA80FC",
    "#FF80AB",
    "#B2FF59",
    "#84FFFF"
  ],
  "good": "#00D4AA",
  "neutral": "#FFD700",
  "bad": "#FF4444",
  "minimum": "#FF4444",
  "center": "#FFD700",
  "maximum": "#00D4AA",
  "background": "#0E1117",
  "foreground": "#FAFAFA",
  "tableAccent": "#00D4FF",
  "textClasses": {
    "callout": {
      "fontSize": 28,
      "fontFace": "Segoe UI",
      "color": "#FAFAFA"
    },
    "title": {
      "fontSize": 14,
      "fontFace": "Segoe UI Semibold",
      "color": "#FAFAFA"
    },
    "header": {
      "fontSize": 12,
      "fontFace": "Segoe UI Semibold",
      "color": "#FAFAFA"
    },
    "label": {
      "fontSize": 10,
      "fontFace": "Segoe UI",
      "color": "#8892A0"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#1A1F2E" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "color": { "solid": { "color": "#2D2D5E" } },
            "show": true,
            "radius": 10
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ],
        "visualHeaderTooltip": [
          {
            "show": true
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#FAFAFA" } },
            "background": { "solid": { "color": "#1A1F2E00" } },
            "alignment": "left",
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "subTitle": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#8892A0" } },
            "fontSize": 9,
            "fontFamily": "Segoe UI"
          }
        ],
        "padding": [
          {
            "top": 8,
            "bottom": 8,
            "left": 10,
            "right": 10
          }
        ],
        "lockAspect": [
          {
            "show": false
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#0E1117" } },
            "transparency": 0
          }
        ]
      }
    },
    "card": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#1A1F2E" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "color": { "solid": { "color": "#2D2D5E" } },
            "show": true,
            "radius": 12
          }
        ],
        "labels": [
          {
            "color": { "solid": { "color": "#FAFAFA" } },
            "fontSize": 28,
            "fontFamily": "Segoe UI"
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "color": { "solid": { "color": "#8892A0" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "multiRowCard": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#1A1F2E" } },
            "transparency": 0
          }
        ],
        "dataLabels": [
          {
            "color": { "solid": { "color": "#FAFAFA" } },
            "fontSize": 20
          }
        ],
        "categoryLabels": [
          {
            "color": { "solid": { "color": "#8892A0" } },
            "fontSize": 10
          }
        ],
        "cardTitle": [
          {
            "color": { "solid": { "color": "#8892A0" } },
            "fontSize": 10
          }
        ]
      }
    },
    "lineChart": {
      "*": {
